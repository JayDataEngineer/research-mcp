# IDE & Editor
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ============================================
# Environment & Secrets (CRITICAL - don't leak!)
# ============================================
.env
.env.local
.env.*.local
*.key
*.pem
*.cert
secrets/
credentials/
.aws/
.secrets/

