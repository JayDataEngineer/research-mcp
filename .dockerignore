lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================
# Virtual Environments (don't copy into image)
# ============================================
.venv/
venv/
ENV/
env/
.ENV/
virtualenv/

