# Research MCP — web research, scraping, structured extraction.
# Copy to .env and edit:  cp .env.example .env

# Required — pick any strong password.
POSTGRES_PASSWORD=change-me

# Optional — default database / user if you want to customize.
# POSTGRES_DB=mcp_server
# POSTGRES_USER=postgres

# Optional — VPN proxy for outbound scraping (ProtonVPN SOCKS5, gluetun, etc.)
# Leave unset to disable proxy support. The stack has NO VPN dependency.
# MCP_PROXY_URL=socks5://gluetun:1080
# MCP_PROXY_URLS=socks5://10.0.0.1:1080,socks5://10.0.0.2:1080
# MCP_PROXY_ROTATION=round-robin

# Optional — Tailnet node name for tailscale-serve URLs (docs / README only;
# the container itself doesn't read this).
# Find your node name with: tailscale status | grep -m1 "$(hostname)"
# TAILNET_HOST=<your-node>.ts.net
# TAILNET_PORT=10000
